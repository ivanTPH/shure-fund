{
  "_readme": "Design tokens extracted from Figma exports in /design-system/. These are the authoritative values — use them in all component code. The web app uses the 'light' theme variants.",

  "color": {
    "brand": {
      "navy":        "#0D1144",
      "navy-muted":  "rgba(13,17,68,0.45)",
      "navy-faint":  "rgba(13,17,68,0.25)"
    },
    "surface": {
      "page":        "#f7f8fc",
      "card":        "#ffffff",
      "border":      "#e4e7f0",
      "border-css":  "var(--surface-border, #e4e7f0)"
    },
    "status": {
      "draft":               "#94a3b8",
      "sent":                "#2563eb",
      "accepted":            "#7c3aed",
      "in_progress":         "#d97706",
      "awaiting_approval":   "#7c3aed",
      "returned":            "#ea580c",
      "disputed":            "#dc2626",
      "available_to_release":"#059669",
      "released":            "#16a34a",
      "funding_gap":         "#dc2626",
      "part_funded":         "#d97706",
      "approved":            "#059669",
      "rejected":            "#dc2626",
      "pending":             "#64748b"
    },
    "role": {
      "funder":     "#059669",
      "developer":  "#2563eb",
      "commercial": "#d97706",
      "contractor": "#ea580c",
      "consultant": "#7c3aed",
      "admin":      "#dc2626"
    },
    "action": {
      "primary-bg":    "#0D1144",
      "primary-text":  "#ffffff",
      "danger-bg":     "#dc2626",
      "warning-bg":    "rgba(217,119,6,0.08)",
      "warning-border":"rgba(217,119,6,0.2)",
      "success-bg":    "rgba(5,150,105,0.08)",
      "success-border":"rgba(5,150,105,0.2)"
    },
    "deprecated": {
      "_note": "These appear in older Figma exports but must NOT be used in code",
      "neon-teal":   "#34d399",
      "neon-green":  "#4ade80",
      "neon-blue":   "#60a5fa",
      "neon-purple": "#c084fc",
      "neon-red":    "#f87171",
      "neon-amber":  "#fbbf24",
      "neon-violet": "#a78bfa",
      "dark-bg-1":   "#0a0a0a",
      "dark-bg-2":   "#111827",
      "dark-bg-3":   "#1a1a1a"
    }
  },

  "radius": {
    "card":    "20px",
    "card-lg": "28px",
    "button":  "12px",
    "input":   "12px",
    "pill":    "9999px"
  },

  "typography": {
    "heading-xl":  { "fontSize": "24px", "fontWeight": 700 },
    "heading-lg":  { "fontSize": "18px", "fontWeight": 700 },
    "heading-sm":  { "fontSize": "14px", "fontWeight": 700 },
    "body":        { "fontSize": "14px", "fontWeight": 400 },
    "label":       { "fontSize": "12px", "fontWeight": 600 },
    "badge":       { "fontSize": "10px", "fontWeight": 700, "textTransform": "uppercase", "letterSpacing": "0.05em" },
    "currency":    "Intl.NumberFormat('en-GB', { style: 'currency', currency: 'GBP', maximumFractionDigits: 0 })",
    "date":        "toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })"
  },

  "navigation": {
    "tabs": ["Notifications", "Projects", "Account", "Funds"],
    "tab-icons": {
      "Notifications": "bell",
      "Projects":      "circle-chart",
      "Account":       "person",
      "Funds":         "pound-circle"
    }
  },

  "components": {
    "card": {
      "backgroundColor": "#fff",
      "border":          "1px solid var(--surface-border, #e4e7f0)",
      "borderRadius":    "20px",
      "padding":         "24px"
    },
    "input": {
      "backgroundColor": "#fff",
      "border":          "1px solid var(--surface-border, #e4e7f0)",
      "borderRadius":    "12px",
      "padding":         "10px 14px",
      "fontSize":        "14px",
      "color":           "var(--brand-navy, #0D1144)"
    },
    "button-primary": {
      "backgroundColor": "#0D1144",
      "color":           "#fff",
      "borderRadius":    "12px",
      "padding":         "12px 24px",
      "fontSize":        "14px",
      "fontWeight":      600
    },
    "status-pill": {
      "borderRadius":    "9999px",
      "padding":         "2px 10px",
      "fontSize":        "10px",
      "fontWeight":      700,
      "textTransform":   "uppercase",
      "letterSpacing":   "0.05em",
      "backgroundAlpha": "18"
    },
    "dashboard-ring": {
      "_note": "Circular progress ring on project dashboard — from Figma dashboard designs",
      "track-color":    "rgba(13,17,68,0.1)",
      "progress-color": "#059669",
      "unfunded-color": "#dc2626",
      "size":           "180px"
    }
  },

  "figma-screens": {
    "_note": "Reference paths to Figma export PNGs in /design-system/",
    "dashboard":           "New Design guids/Dashboard-4.png",
    "dashboard-unfunded":  "New Design guids/Dashboard-5.png",
    "projects-list":       "New Design guids/Projects-2.png",
    "contract-detail":     "New Design guids/Individual Contract-2.png",
    "contract-completed":  "New Design guids/Individual Contract compleated-2.png",
    "contract-summary":    "New Design guids/Contract summary-2.png",
    "kyc":                 "New Design guids/KYC-2.png",
    "account-setup":       "New Design guids/Account set up-2.png",
    "home":                "New Design guids/Home-2.png",
    "notifications":       "New Design guids/Notifications strings page-2.png",
    "sign-in":             "New Design guids/Sign In-2.png",
    "new-project":         "New Design guids/New Project-2.png",
    "new-contract":        "New Design guids/New Contract-2.png"
  }
}
