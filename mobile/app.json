{
  "expo": {
    "name": "Shure.Fund",
    "slug": "shure-fund",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "shurefund",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d1144"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fund.shure.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1144"
      },
      "package": "fund.shure.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0d1144"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
