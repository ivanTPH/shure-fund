# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used in email links — set to your Vercel deployment URL)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Email (Resend — omit to log emails to console instead of sending)
RESEND_API_KEY=
EMAIL_FROM=noreply@shure.fund

# Daily digest cron auth (generate a random secret, set same value in Vercel)
DIGEST_SECRET=

# Web Push (VAPID) — generate once with: node -e "require('web-push').generateVAPIDKeys()" | npx web-push generate-vapid-keys
# Leave blank to disable browser push notifications (Expo push still works)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@shure.fund
