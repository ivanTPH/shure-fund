# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL (used in email links — set to your Vercel deployment URL)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Email (Resend — omit to log emails to console instead of sending)
RESEND_API_KEY=
EMAIL_FROM=noreply@shure.fund

# Daily digest cron auth (generate a random secret, set same value in Vercel)
DIGEST_SECRET=
